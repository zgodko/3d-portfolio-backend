{
  "version": 6,
  "configurePresets": [
    {
      "name": "msys2-ucrt64",
      "displayName": "MSYS2 UCRT64 (Ninja)",
      "description": "Сборка с помощью g++ из MSYS2 UCRT64",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "C:/msys64/ucrt64/bin/gcc.exe",
        "CMAKE_CXX_COMPILER": "C:/msys64/ucrt64/bin/g++.exe",
        "CMAKE_BUILD_TYPE": "Debug"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "msys2-ucrt64-debug",
      "configurePreset": "msys2-ucrt64"
    }
  ]
}